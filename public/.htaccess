<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /ikizamini/public/
    
    # Don't rewrite if the request is for a real file
    RewriteCond %{REQUEST_FILENAME} !-f
    # Don't rewrite if the request is for a real directory
    RewriteCond %{REQUEST_FILENAME} !-d
    
    # Rewrite all requests to index.php with query string
    RewriteRule ^(.*)$ index.php?url=$1 [QSA,L]
</IfModule>
